CONFLUENCE_BASE_URL=https://confluence.your-company.internal
CONFLUENCE_API_PATH=/rest/api

# Recommended for Confluence Data Center: personal access token / bearer auth.
# Read tools require read access. Write tools require page/comment create or edit access.
CONFLUENCE_AUTH_MODE=bearer
CONFLUENCE_PAT=replace-me

# Alternate Data Center setup: basic auth with username/password
# CONFLUENCE_AUTH_MODE=basic
# CONFLUENCE_USERNAME=confluence-bot
# CONFLUENCE_PASSWORD=replace-me

# Confluence Cloud setup, if you ever need it:
# CONFLUENCE_AUTH_MODE=basic
# CONFLUENCE_EMAIL=confluence-bot@your-company.com
# CONFLUENCE_API_TOKEN=replace-me

# Optional defaults
# CONFLUENCE_SPACE_KEY=ENG
# CONFLUENCE_CQL_FILTER=label = "public-docs"
